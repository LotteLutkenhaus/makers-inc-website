---
import BlogCard from './BlogCard.astro';

interface Props {
  posts: Parameters<typeof BlogCard>[0]['post'][];
  showCategory?: boolean;
}

const { posts, showCategory = false } = Astro.props;
---

<div class="posts-grid">
  {posts.map((post) => (
    <BlogCard post={post} showCategory={showCategory} />
  ))}
</div>

<style>
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 900px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
