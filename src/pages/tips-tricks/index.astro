---
import Layout from '../../layouts/Layout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getBlogPostsByCategory } from '../../lib/contentful';

const posts = await getBlogPostsByCategory('Tips & Tricks');
---

<Layout title="Tips &amp; Tricks">
  <div class="page-header">
    <div class="container">
      <h1 class="page-title">Tips en Tricks</h1>
      <p class="page-desc"><em>Toe aan wat meer uitdaging? Hier vind je de handigste hacks, en leuke tutorials om jouw skills een level-up te geven!</em></p>
    </div>
  </div>

  <section class="posts-section">
    <div class="container">
      <div class="posts-grid">
        {posts.map((post) => (
          <BlogCard post={post} />
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .posts-section {
    padding: 4rem 0;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 900px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
