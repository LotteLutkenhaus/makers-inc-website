---
import { Image } from 'astro:assets';
import Layout from './Layout.astro';
import { renderMarkdown } from '../lib/markdown';
import { getProduct } from '../lib/contentful';

interface Props {
  post: {
    fields: {
      title: string;
      heroImage?: unknown;
      category?: unknown[];
      body: string;
    };
  };
}

const { post } = Astro.props;
const { title, heroImage, category, body } = post.fields;

const html = renderMarkdown(body ?? '');

const categories = category as any[] | undefined;
const categoryName: string = categories?.[0]?.fields?.name ?? '';

function categoryHref(name: string): string {
  if (name === 'Alles voor beginners') return '/beginners/';
  if (name === 'Tips & Tricks') return '/tips-tricks/';
  return '/';
}

const backHref = categoryHref(categoryName);
const backLabel = categoryName || 'Blog';

const imageAsset = heroImage as any;
const imageUrl: string | null = imageAsset?.fields?.file?.url
  ? `https:${imageAsset.fields.file.url}`
  : null;

const product = await getProduct('naaipatroon-maxi-wikkelrok');
const donationUrl = product?.fields.stripePaymentLink ?? '#';
---

<Layout title={title}>
  <article class="blog-post">
    {imageUrl && (
      <div class="post-hero">
        <Image
          src={imageUrl}
          width={1200}
          height={675}
          alt={title}
          class="post-hero-image"
          loading="eager"
        />
      </div>
    )}

    <div class="post-header container">
      <a href={backHref} class="post-back">&larr; Terug naar {backLabel}</a>
      {categoryName && <span class="post-category">{categoryName}</span>}
      <h1 class="post-title">{title}</h1>
    </div>

    <div class="post-body container" set:html={html} />

    <div class="post-donation">
      <a href={donationUrl} class="btn-primary">Vind je dit artikel waardevol? Trakteer me op een koffie ☕</a>
    </div>
  </article>
</Layout>

<style>
  .blog-post {
    padding-bottom: 4rem;
  }

  .post-hero {
    width: 100%;
    max-height: 520px;
    overflow: hidden;
  }

  .post-hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .post-header {
    max-width: 680px;
    margin: 2.5rem auto;
  }

  .post-back {
    display: inline-block;
    margin-bottom: 1rem;
    color: var(--color-muted);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .post-back:hover {
    color: var(--color-accent);
  }

  .post-category {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--color-accent);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .post-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    color: var(--color-primary);
    line-height: 1.2;
  }

  /* ── Article body typography ── */
  .post-body {
    max-width: 680px;
    margin: 0 auto 3rem;
  }

  .post-body :global(p) {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--color-text);
    margin-bottom: 1.5rem;
  }

  .post-body :global(h2) {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.6rem;
    color: var(--color-primary);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .post-body :global(h3) {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.3rem;
    color: var(--color-primary);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .post-body :global(a) {
    color: var(--color-accent);
    text-decoration: none;
  }

  .post-body :global(a:hover) {
    text-decoration: underline;
  }

  .post-body :global(img) {
    width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
    margin: 1.5rem 0;
  }

  .post-body :global(blockquote) {
    border-left: 4px solid var(--color-accent);
    padding-left: 1.25rem;
    margin: 2rem 0;
    font-family: var(--font-heading);
    font-style: italic;
    color: var(--color-muted);
  }

  .post-body :global(strong) {
    font-weight: 700;
    color: var(--color-primary);
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .post-body :global(li) {
    font-size: 1.1rem;
    line-height: 1.8;
    margin-bottom: 0.5rem;
  }

  /* ── Donation ── */
  .post-donation {
    text-align: center;
    padding: 2rem 1rem 0;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .post-hero {
      max-height: 260px;
    }
  }
</style>
