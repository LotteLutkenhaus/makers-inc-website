---
import Layout from '../layouts/Layout.astro';
import BlogCard from '../components/BlogCard.astro';
import { Image } from 'astro:assets';
import { getBlogPosts, getSiteInfoById, getProduct } from '../lib/contentful';

const siteInfo = await getSiteInfoById('SYJXpMEX8IfUNLU5gBqae');
const posts = await getBlogPosts();
const recentPosts = posts.slice(0, 6);
const product = await getProduct('naaipatroon-maxi-wikkelrok');

const heroAsset = siteInfo?.fields.frontPageImage as any;
const heroImageUrl: string | null = heroAsset?.fields?.file?.url
  ? `https:${heroAsset.fields.file.url}`
  : null;

const productPrice = product?.fields.price as number | undefined;
---

<Layout title="Home">
  <!-- Hero: full-width green with portrait photo frame -->
  <section class="hero">
    <div class="hero-text">
      <h1 class="hero-heading">
        Hi! Ik ben<br>
        <span class="accent">Lotte.</span>
      </h1>
      <p class="hero-tagline">
        {siteInfo?.fields.heroText ?? 'Makers Inc. is mijn blog, waarin ik handige tips en tricks voor het naaien van kleding met je deel.'}
      </p>
    </div>
    <div class="hero-image">
      <div class="image-mat">
        {heroImageUrl && (
          <Image
            src={heroImageUrl}
            alt="Lotte aan haar naaimachine"
            width={680}
            height={906}
            style="width:100%;height:100%;object-fit:cover;object-position:center 15%;"
            loading="eager"
          />
        )}
        <div class="image-mat-label">Makers Inc.</div>
      </div>
    </div>
  </section>

  <!-- Diagonal transition strip -->
  <div class="hero-bottom"></div>

  <!-- Micro-intro strip -->
  <section class="intro" id="meer">
    <div class="intro-inner">
      <p>Naaien lijkt ingewikkeld, maar dat hoeft het niet te zijn. Op Makers Inc. vind je <strong class="intro-emphasis">eerlijke tutorials, praktische tips en naaipatronen</strong>, speciaal geschreven voor beginners. Lekker aan de slag!</p>
    </div>
  </section>

  <!-- Callout cards -->
  <section class="callout-section">
    <div class="container">
      <h2 class="section-title">Nieuw hier?</h2>
      <div class="callout-cards">
        <a
          href="/blog/naaien-voor-beginners-stap-voor-stap-tutorial-voor-een-etui/"
          class="callout-card"
        >
          <span class="callout-label">Gratis tutorial</span>
          <h3 class="callout-card-title">Leer stap voor stap een etui naaien</h3>
          <p class="callout-card-body">Perfect beginnersproject! En: je leert op een makkelijke manier een rits in te zetten.</p>
          <span class="callout-pill callout-pill--gratis">&#x2713; Gratis</span>
        </a>
        <a href="/product/naaipatroon-maxi-wikkelrok/" class="callout-card">
          <span class="callout-label">Naaipatroon</span>
          <h3 class="callout-card-title">Maxi-wikkelrok: je eerste kledingstuk</h3>
          <p class="callout-card-body">Eenvoudig in elkaar te zetten, met een maximaal zwierig resultaat!</p>
          {productPrice !== undefined && (
            <span class="callout-pill callout-pill--price">&euro;{productPrice.toFixed(2)}</span>
          )}
        </a>
      </div>
    </div>
  </section>

  <!-- Recente blogposts -->
  <section class="recent-posts">
    <div class="container">
      <h2 class="section-title">Recente blogposts</h2>
      <div class="posts-grid">
        {recentPosts.map((post) => (
          <BlogCard post={post} />
        ))}
      </div>
      <div class="posts-cta">
        <a href="/beginners/" class="btn-outline">Alle blogposts bekijken &rarr;</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── Hero ── */
  .hero {
    background: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6%;
    padding: 2rem 7% 0.5rem;
  }

  .hero-text {
    flex: 1 1 50%;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 520px;
  }

  .hero-heading {
    font-family: var(--font-heading);
    font-size: clamp(2.8rem, 5.5vw, 4.75rem);
    font-weight: 700;
    line-height: 1.0;
    color: var(--color-bg);
    letter-spacing: -0.01em;
  }
  .hero-heading .accent {
    color: var(--color-accent);
    font-style: italic;
  }

  .hero-tagline {
    font-size: 1rem;
    line-height: 1.75;
    color: rgba(253, 250, 247, 0.72);
    max-width: 38ch;
  }

  .hero-image {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-bottom: 1.5rem;
    padding-right: 1.5rem;
  }

  .image-mat {
    position: relative;
    width: clamp(200px, 26vw, 340px);
    aspect-ratio: 3 / 4;
    background: var(--color-accent);
    padding: 8px 8px 44px 8px;
    border-radius: 3px;
    box-shadow: 14px 14px 0 rgba(0, 0, 0, 0.25);
    flex-shrink: 0;
  }

  .image-mat img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 15%;
    border-radius: 1px;
  }

  .image-mat-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-logo);
    font-size: 0.6rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.9);
  }

  .hero-bottom {
    background: var(--color-primary);
    height: 3rem;
    margin-top: -2px;
    clip-path: polygon(0 0, 100% 0, 100% 30%, 0 100%);
  }

  /* ── Mobile hero: full-bleed image + text overlay ── */
  @media (max-width: 768px) {
    .hero {
      flex-direction: column;
      padding: 0;
      gap: 0;
      position: relative;
    }

    .hero-image {
      width: 100%;
      padding: 0;
      order: -1;
    }

    .image-mat {
      width: 100%;
      aspect-ratio: 3 / 4;
      padding: 0;
      border-radius: 0;
      box-shadow: none;
    }
    .image-mat::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to top,
        rgba(0, 0, 0, 0.72) 0%,
        rgba(0, 0, 0, 0.25) 55%,
        transparent 100%
      );
    }
    .image-mat img { border-radius: 0; }
    .image-mat-label { display: none; }

    .hero-text {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 1;
      padding: 2rem 1.5rem 2.5rem;
      gap: 0.6rem;
      max-width: none;
      background: transparent;
    }

    .hero-heading { font-size: 2.4rem; }
    .hero-tagline {
      color: rgba(253, 250, 247, 0.85);
      font-size: 0.95rem;
    }

    .hero-bottom { display: none; }
  }

  /* ── Micro-intro ── */
  .intro {
    background: var(--color-bg);
    padding: 3.5rem 2rem;
  }

  @media (max-width: 768px) {
    .intro {
      padding-top: 2rem;
    }
  }

  .intro-inner {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
    padding: 1.5rem 2rem;
    text-align: center;
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .intro-inner::before,
  .intro-inner::after {
    content: '';
    position: absolute;
    width: 1.25rem;
    height: 1.25rem;
  }
  .intro-inner::before {
    top: 0;
    left: 0;
    border-top: 2px solid var(--color-accent);
    border-left: 2px solid var(--color-accent);
  }
  .intro-inner::after {
    bottom: 0;
    right: 0;
    border-bottom: 2px solid var(--color-accent);
    border-right: 2px solid var(--color-accent);
  }

  .intro-emphasis {
    font-weight: 700;
    color: var(--color-primary);
  }

  /* ── Callout cards ── */
  .callout-section {
    background: var(--color-bg);
    padding: 4rem 0;
  }

  .section-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.8rem;
    color: var(--color-primary);
    margin-bottom: 2rem;
  }

  .callout-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .callout-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 2rem;
    background: var(--color-surface);
    border: 1.5px solid var(--color-border);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .callout-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }

  .callout-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }

  .callout-card:hover::before {
    transform: scaleX(1);
  }

  .callout-label {
    color: var(--color-accent);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .callout-card-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.2rem;
    color: var(--color-primary);
    line-height: 1.3;
  }

  .callout-card-body {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-muted);
    flex-grow: 1;
  }

  .callout-pill {
    display: inline-block;
    align-self: flex-start;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .callout-pill--gratis,
  .callout-pill--price {
    background: rgba(46, 87, 68, 0.12);
    color: var(--color-primary);
  }

  /* ── Recente blogposts ── */
  .recent-posts {
    padding: 4rem 0;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .posts-cta {
    text-align: center;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .callout-cards {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 900px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
