---
import Layout from '../../layouts/Layout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getBlogPostsByCategory } from '../../lib/contentful';

const posts = await getBlogPostsByCategory('Alles voor beginners');
---

<Layout title="Alles voor beginners">
  <div class="page-header">
    <div class="container">
      <h1 class="page-title">Alles voor beginners</h1>
      <p class="page-desc"><em>Hier begin je.</em></p>
    </div>
  </div>

  <section class="posts-section">
    <div class="container">
      <div class="posts-grid">
        {posts.map((post) => (
          <BlogCard post={post} />
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background: var(--color-primary);
    padding: 4rem 0;
  }

  .page-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(2rem, 5vw, 3rem);
    color: #fff;
    margin-bottom: 0.75rem;
  }

  .page-desc {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.8);
  }

  .posts-section {
    padding: 4rem 0;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 900px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
