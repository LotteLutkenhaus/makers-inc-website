---
import '../styles/global.css';
import { Image } from 'astro:assets';
import { getSiteInfoById } from '../lib/contentful';
import { contentfulImageUrl } from '../lib/contentful-image';
import SEO from '../components/SEO.astro';
import nunitoLatinUrl from '@fontsource-variable/nunito/files/nunito-latin-wght-normal.woff2?url';
import frauncesLatinUrl from '@fontsource-variable/fraunces/files/fraunces-latin-opsz-normal.woff2?url';
import unicaOneLatinUrl from '@fontsource/unica-one/files/unica-one-latin-400-normal.woff2?url';

interface Props {
  title: string;
  titleAccent?: boolean;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  datePublished?: string;
  dateModified?: string;
}

const { title, titleAccent = true, description, ogImage, ogType, datePublished, dateModified } = Astro.props;
const pathname = Astro.url.pathname;
const canonicalUrl = `https://www.makersinc.nl${pathname}`;

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}

const siteInfo = await getSiteInfoById('SYJXpMEX8IfUNLU5gBqae');
const logoAsset = siteInfo?.fields.logoWide as any;
const rawLogoUrl: string | null = logoAsset?.fields?.file?.url
  ? `https:${logoAsset.fields.file.url}`
  : null;
const logoUrl: string | null = rawLogoUrl ? contentfulImageUrl(rawLogoUrl, 'logo') : null;
const logoWidth = 250;
const logoHeight = 96;
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="preload" href={nunitoLatinUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={frauncesLatinUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={unicaOneLatinUrl} as="font" type="font/woff2" crossorigin />
    <SEO
      {title}
      {description}
      {canonicalUrl}
      {ogImage}
      {ogType}
      {datePublished}
      {dateModified}
    />
  </head>
  <body>
    <header class="site-nav" data-solid={pathname !== '/' ? 'true' : 'false'}>
      <div class="container nav-inner">
        <a href="/" class="nav-logo">
          {logoUrl ? (
            <Image
              src={logoUrl}
              width={logoWidth}
              height={logoHeight}
              alt="Makers Inc."
              class="nav-logo-image"
            />
          ) : (
            <span>🧵 Makers Inc.</span>
          )}
        </a>
        <nav class="nav-links" aria-label="Hoofdnavigatie">
          <a href="/beginners/" class:list={['nav-link', { 'nav-link--active': isActive('/beginners/') }]}>Voor beginners</a>
          <a href="/tips-tricks/" class:list={['nav-link', { 'nav-link--active': isActive('/tips-tricks/') }]}>Tips &amp; Tricks</a>
          <a href="/shop/" class:list={['nav-link', { 'nav-link--active': isActive('/shop/') }]}>Patronen</a>
          <a href="/over/" class:list={['nav-link', { 'nav-link--active': isActive('/over/') }]}>Over mij</a>
          <a href="/contact/" class:list={['nav-link', { 'nav-link--active': isActive('/contact/') }]}>Contact</a>
        </nav>
        <button
          class="nav-hamburger"
          id="nav-hamburger"
          aria-label="Menu openen"
          aria-expanded="false"
          aria-controls="nav-overlay"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </header>

    <div class="nav-overlay" id="nav-overlay" aria-label="Navigatiemenu">
      <button class="nav-overlay-close" id="nav-overlay-close" aria-label="Menu sluiten">&#x2715;</button>
      <nav class="nav-overlay-links" aria-label="Mobiele navigatie">
        <a href="/beginners/" class="nav-overlay-link">Voor beginners</a>
        <a href="/tips-tricks/" class="nav-overlay-link">Tips &amp; Tricks</a>
        <a href="/shop/" class="nav-overlay-link">Patronen</a>
        <a href="/over/" class="nav-overlay-link">Over mij</a>
        <a href="/contact/" class="nav-overlay-link">Contact</a>
      </nav>
    </div>

    <main class:list={[{ 'no-title-accent': !titleAccent, 'interior-page': pathname !== '/' }]}>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <a href="/" class="footer-logo">
          {logoUrl ? (
            <Image
              src={logoUrl}
              width={logoWidth}
              height={logoHeight}
              alt="Makers Inc."
              class="footer-logo-image"
            />
          ) : (
            <span>🧵 Makers Inc.</span>
          )}
        </a>
        <nav class="footer-nav" aria-label="Footernavigatie">
          <a href="/contact/">Contact</a>
          <a href="/privacyverklaring/">Privacyverklaring</a>
          <a href="/algemene-voorwaarden/">Algemene voorwaarden</a>
        </nav>
        <div class="footer-right">
          <a href="https://www.instagram.com/makersinc.nl/" class="footer-instagram" aria-label="Volg Makers Inc. op Instagram" rel="noopener noreferrer" target="_blank">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
          </a>
          <p class="footer-copy">&copy; {new Date().getFullYear()} Makers Inc.</p>
        </div>
      </div>
    </footer>

    <script>
      // Nav starts light/transparent on load → solid green on scroll
      const siteNav = document.querySelector<HTMLElement>('.site-nav');
      const isSolid = siteNav?.dataset.solid === 'true';
      function updateNav() {
        if (isSolid) return;
        siteNav?.classList.toggle('site-nav--light', window.scrollY < 10);
      }
      window.addEventListener('scroll', updateNav, { passive: true });
      updateNav();

      const hamburger = document.getElementById('nav-hamburger');
      const overlay = document.getElementById('nav-overlay');
      const closeBtn = document.getElementById('nav-overlay-close');

      function openMenu() {
        overlay?.classList.add('nav-overlay--open');
        hamburger?.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      }

      function closeMenu() {
        overlay?.classList.remove('nav-overlay--open');
        hamburger?.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }

      hamburger?.addEventListener('click', openMenu);
      closeBtn?.addEventListener('click', closeMenu);
    </script>

    <style>
      /* ── Nav ── */
      .site-nav {
        position: sticky;
        top: 0;
        z-index: 100;
        background: var(--color-primary);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
        transition: background 0.35s ease, box-shadow 0.35s ease;
      }

      .site-nav--light {
        background: var(--color-bg);
        box-shadow: 0 1px 0 var(--color-border);
      }


      .nav-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 64px;
      }

      .nav-logo {
        font-family: var(--font-logo);
        font-size: 1.4rem;
        color: #fff;
        text-decoration: none;
        letter-spacing: 0.02em;
        flex-shrink: 0;
        display: flex;
        align-items: center;
      }

      .nav-logo-image {
        height: 48px;
        width: auto;
        display: block;
        transition: filter 0.35s ease;
      }


      .nav-links {
        display: flex;
        gap: 2rem;
        align-items: center;
      }

      .nav-link {
        font-family: var(--font-body);
        font-weight: 700;
        font-size: 1.05rem;
        color: rgba(255, 255, 255, 0.85);
        text-decoration: none;
        transition: color 0.2s;
      }

      .nav-link:hover,
      .nav-link--active {
        color: var(--color-accent);
      }

      .site-nav--light .nav-link {
        color: var(--color-primary);
      }

      .site-nav--light .nav-link:hover,
      .site-nav--light .nav-link--active {
        color: var(--color-accent);
      }

      .nav-hamburger {
        display: none;
        flex-direction: column;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 4px;
      }

      .nav-hamburger span {
        display: block;
        width: 24px;
        height: 2px;
        background: #fff;
        border-radius: 2px;
        transition: background 0.35s ease;
      }

      .site-nav--light .nav-hamburger span {
        background: var(--color-primary);
      }

      /* ── Mobile overlay ── */
      .nav-overlay {
        position: fixed;
        inset: 0;
        background: var(--color-primary);
        z-index: 200;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        transform: translateX(100%);
        transition: transform 0.3s ease;
      }

      .nav-overlay--open {
        transform: translateX(0);
      }

      .nav-overlay-close {
        position: absolute;
        top: 1.5rem;
        right: 1.5rem;
        background: none;
        border: none;
        color: #fff;
        font-size: 1.5rem;
        cursor: pointer;
        padding: 0.5rem;
        line-height: 1;
      }

      .nav-overlay-links {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
      }

      .nav-overlay-link {
        font-family: var(--font-body);
        font-weight: 700;
        font-size: 1.5rem;
        color: #fff;
        text-decoration: none;
        transition: color 0.2s;
      }

      .nav-overlay-link:hover {
        color: var(--color-accent);
      }

      /* ── Interior page spacing ── */
      .interior-page {
        padding-top: 3.5rem;
      }

      /* ── Footer ── */
      .site-footer {
        background: var(--color-primary);
        padding: 3rem 0;
        margin-top: 4rem;
      }

      .footer-inner {
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 2rem;
      }

      .footer-logo {
        font-family: var(--font-logo);
        font-size: 1.2rem;
        color: #fff;
        text-decoration: none;
        display: flex;
        align-items: center;
      }

      .footer-logo-image {
        height: 48px;
        width: auto;
        display: block;
      }

      .footer-nav {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.5rem 1.5rem;
      }

      .footer-nav a {
        font-family: var(--font-body);
        font-size: 0.875rem;
        color: rgba(255, 255, 255, 0.75);
        text-decoration: none;
        transition: color 0.2s;
      }

      .footer-nav a:hover {
        color: var(--color-accent);
      }

      .footer-right {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 1rem;
      }

      .footer-instagram {
        color: rgba(255, 255, 255, 0.75);
        display: flex;
        align-items: center;
        transition: color 0.2s;
      }

      .footer-instagram:hover {
        color: var(--color-accent);
      }

      .footer-copy {
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.5);
        white-space: nowrap;
      }

      /* ── Responsive ── */
      @media (max-width: 768px) {
        .nav-links {
          display: none;
        }

        .nav-hamburger {
          display: flex;
        }

        .footer-inner {
          grid-template-columns: 1fr;
          text-align: center;
          justify-items: center;
        }
      }
    </style>
  </body>
</html>