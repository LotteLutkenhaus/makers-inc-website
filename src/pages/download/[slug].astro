---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { getDownloads } from '../../lib/contentful';

export async function getStaticPaths() {
  const downloads = await getDownloads();
  return downloads.map((dl) => ({
    params: { slug: dl.fields.slug },
    props: { download: dl },
  }));
}

const { download } = Astro.props;
const title = download.fields.title ?? '';
const description = download.fields.description ?? '';

const file = download.fields.file as any;
const fileUrl = file?.fields?.file?.url ?? '#';
const fullFileUrl = fileUrl.startsWith('//') ? `https:${fileUrl}` : fileUrl;

const imageAsset = (download.fields as any).image as any;
const imageUrl: string | null = imageAsset?.fields?.file?.url
  ? `https:${imageAsset.fields.file.url}`
  : null;
---

<Layout title={title}>
  <div class="page-header">
    <div class="container">
      <a href="/shop/" class="back-link">&larr; Alle patronen</a>
    </div>
  </div>

  <section class="download-section">
    <div class="container download-layout">

      <div class="download-main">
        {imageUrl && (
          <div class="download-image-wrap">
            <Image
              src={imageUrl}
              width={560}
              height={560}
              alt={title}
              class="download-image"
            />
          </div>
        )}

        <div class="download-info">
          <span class="download-badge">Gratis patroon</span>
          <h1 class="download-title">{title}</h1>
          {description && <p class="download-desc">{description}</p>}

          <a href={fullFileUrl} download class="btn-primary download-btn">
            Patroon downloaden
          </a>
          <p class="download-hint">PDF — gratis te downloaden</p>
        </div>
      </div>

      <aside class="donate-aside">
        <div class="donate-card">
          <p class="donate-card-icon" aria-hidden="true">☕</p>
          <h2 class="donate-card-title">Vond je dit patroon leuk?</h2>
          <p class="donate-card-text">
            Dit patroon is en blijft gratis. Maar als je er blij van wordt, zou een kleine donatie me enorm helpen om meer patronen en content te blijven maken.
          </p>
          <p class="donate-card-text">
            Helemaal niet verplicht — je download staat altijd voor je klaar!
          </p>
          <a href="/donate/" class="btn-outline donate-link">Doneer een bedrag naar keuze</a>
          <p class="donate-card-signature">— Lotte</p>
        </div>
      </aside>

    </div>
  </section>
</Layout>

<style>
  .page-header {
    background: var(--color-primary);
    padding: 1.25rem 0;
  }

  .back-link {
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: #fff;
  }

  .download-section {
    padding: 4rem 0 5rem;
  }

  .download-layout {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 4rem;
    align-items: start;
  }

  .download-main {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .download-image-wrap {
    border-radius: 12px;
    overflow: hidden;
    max-width: 480px;
  }

  .download-image {
    width: 100%;
    height: auto;
    display: block;
  }

  .download-badge {
    display: inline-block;
    background: var(--color-accent);
    color: #fff;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-radius: 99px;
    padding: 0.3rem 0.9rem;
    margin-bottom: 1rem;
  }

  .download-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    color: var(--color-primary);
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .download-desc {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-text);
    margin-bottom: 2rem;
    max-width: 560px;
  }

  .download-btn {
    display: inline-block;
  }

  .download-hint {
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  /* ── Donation aside ── */
  .donate-aside {
    position: sticky;
    top: 6rem;
  }

  .donate-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 2rem 2rem 2.25rem;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
  }

  .donate-card-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .donate-card-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.35rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .donate-card-text {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .donate-link {
    display: block;
    text-align: center;
    margin-top: 1.5rem;
    text-decoration: none;
  }

  .donate-card-signature {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1rem;
    color: var(--color-primary);
    text-align: right;
    margin-top: 1.25rem;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .download-layout {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .donate-aside {
      position: static;
      max-width: 480px;
    }
  }
</style>
