---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { getProduct } from '../../lib/contentful';
import { renderMarkdown } from '../../lib/markdown';

export async function getStaticPaths() {
  const slugs = ['naaipatroon-maxi-wikkelrok'];
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const product = await getProduct(slug);

if (!product) {
  return Astro.redirect('/shop/');
}

const displayName = (product.fields.newName ?? product.fields.name) as string;

const stripeUrl = (import.meta.env.DEV
  ? import.meta.env.STRIPE_PRODUCT_TEST_URL
  : import.meta.env.STRIPE_PRODUCT_URL)
  ?? product.fields.stripePaymentLink
  ?? null;

// Build ordered image list: mainImage first, then additionalImages
const mainImageAsset = (product.fields.mainImage ?? product.fields.image) as any;
const additionalAssets = (product.fields.additionalImages ?? []) as any[];

const allImages: { url: string; alt: string }[] = [];
if (mainImageAsset?.fields?.file?.url) {
  allImages.push({ url: `https:${mainImageAsset.fields.file.url}`, alt: displayName });
}
for (const asset of additionalAssets) {
  const url = asset?.fields?.file?.url;
  if (url) allImages.push({ url: `https:${url}`, alt: displayName });
}
---

<Layout title={displayName}>
  <section class="product-section">
    <div class="container product-layout">

      <!-- Carousel -->
      <div class="carousel-wrap">
        <div class="carousel" id="product-carousel">
          {allImages.length > 0 ? (
            <>
              <div class="carousel-track" id="carousel-track">
                {allImages.map((img, i) => (
                  <div
                    class="carousel-slide"
                    data-index={i}
                    data-src={`${img.url}?w=1200&fm=webp`}
                    data-alt={img.alt}
                  >
                    <Image
                      src={img.url}
                      width={600}
                      height={600}
                      alt={img.alt}
                      class="carousel-image"
                      loading={i === 0 ? 'eager' : 'lazy'}
                    />
                  </div>
                ))}
              </div>

              {allImages.length > 1 && (
                <>
                  <button class="carousel-btn carousel-btn--prev" id="carousel-prev" aria-label="Vorige afbeelding">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <polyline points="15 18 9 12 15 6"/>
                    </svg>
                  </button>
                  <button class="carousel-btn carousel-btn--next" id="carousel-next" aria-label="Volgende afbeelding">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <polyline points="9 18 15 12 9 6"/>
                    </svg>
                  </button>

                  <div class="carousel-dots" id="carousel-dots">
                    {allImages.map((_, i) => (
                      <button
                        class={`carousel-dot${i === 0 ? ' carousel-dot--active' : ''}`}
                        data-index={i}
                        aria-label={`Afbeelding ${i + 1}`}
                      />
                    ))}
                  </div>
                </>
              )}
            </>
          ) : (
            <div class="carousel-placeholder"></div>
          )}
        </div>

        {allImages.length > 1 && (
          <div class="carousel-thumbs" id="carousel-thumbs">
            {allImages.map((img, i) => (
              <button
                class={`carousel-thumb${i === 0 ? ' carousel-thumb--active' : ''}`}
                data-index={i}
                aria-label={`Afbeelding ${i + 1}`}
              >
                <Image
                  src={img.url}
                  width={120}
                  height={120}
                  alt={img.alt}
                  class="carousel-thumb-img"
                  loading="lazy"
                />
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- Details -->
      <div class="product-details">
        <a href="/shop/" class="back-link">&larr; Alle patronen</a>
        <h1 class="product-name">{displayName}</h1>
        {product.fields.description && (
          <div class="product-desc" set:html={renderMarkdown(product.fields.description)} />
        )}
        {product.fields.price !== undefined && (
          <p class="product-price">&euro;{(product.fields.price as number).toFixed(2)}</p>
        )}
        {stripeUrl && (
          <a href={stripeUrl} class="btn-primary">Kopen</a>
        )}
      </div>

    </div>
  </section>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Vergroot afbeelding">
    <button class="lightbox-close" id="lightbox-close" aria-label="Sluiten">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
    <div class="lightbox-backdrop" id="lightbox-backdrop"></div>
    <button class="lightbox-nav lightbox-nav--prev" id="lightbox-prev" aria-label="Vorige afbeelding">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
    </button>
    <button class="lightbox-nav lightbox-nav--next" id="lightbox-next" aria-label="Volgende afbeelding">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </button>
    <div class="lightbox-content">
      <img src="" alt="" class="lightbox-image" id="lightbox-image" />
    </div>
  </div>
</Layout>

<script>
  const track = document.getElementById('carousel-track');
  const prevBtn = document.getElementById('carousel-prev');
  const nextBtn = document.getElementById('carousel-next');
  const dots = document.querySelectorAll<HTMLButtonElement>('.carousel-dot');
  const thumbs = document.querySelectorAll<HTMLButtonElement>('.carousel-thumb');
  const slides = document.querySelectorAll<HTMLElement>('.carousel-slide');
  const totalSlides = slides.length;

  // ── Preload lightbox images in the background ──
  slides.forEach((slide) => {
    const src = slide.dataset.src;
    if (src) {
      const img = new Image();
      img.src = src;
    }
  });

  // ── Carousel navigation ──
  let current = 0;

  function goTo(index: number) {
    current = (index + totalSlides) % totalSlides;
    if (track) (track as HTMLElement).style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((dot, i) => dot.classList.toggle('carousel-dot--active', i === current));
    thumbs.forEach((thumb, i) => thumb.classList.toggle('carousel-thumb--active', i === current));
  }

  if (track && totalSlides > 1) {
    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));
    thumbs.forEach((thumb, i) => thumb.addEventListener('click', () => goTo(i)));

    let touchStartX = 0;
    track.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
    track.addEventListener('touchend', (e) => {
      const diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) goTo(diff > 0 ? current + 1 : current - 1);
    });
  }

  // ── Lightbox ──
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-image') as HTMLImageElement | null;
  const lightboxClose = document.getElementById('lightbox-close');
  const lightboxBackdrop = document.getElementById('lightbox-backdrop');
  const lightboxPrev = document.getElementById('lightbox-prev');
  const lightboxNext = document.getElementById('lightbox-next');

  function showLightboxSlide(index: number) {
    const slide = slides[index];
    if (!slide || !lightboxImg) return;
    lightboxImg.src = slide.dataset.src ?? '';
    lightboxImg.alt = slide.dataset.alt ?? '';
    // Keep carousel in sync
    goTo(index);
    // Hide nav buttons when only one image
    const hasMultiple = totalSlides > 1;
    if (lightboxPrev) lightboxPrev.style.display = hasMultiple ? '' : 'none';
    if (lightboxNext) lightboxNext.style.display = hasMultiple ? '' : 'none';
  }

  function openLightbox() {
    if (!lightbox) return;
    showLightboxSlide(current);
    lightbox.classList.add('lightbox--open');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox?.classList.remove('lightbox--open');
    document.body.style.overflow = '';
  }

  slides.forEach((slide) => {
    slide.querySelector('.carousel-image')?.addEventListener('click', openLightbox);
  });

  lightboxClose?.addEventListener('click', closeLightbox);
  lightboxBackdrop?.addEventListener('click', closeLightbox);

  lightboxPrev?.addEventListener('click', () => showLightboxSlide((current - 1 + totalSlides) % totalSlides));
  lightboxNext?.addEventListener('click', () => showLightboxSlide((current + 1) % totalSlides));

  document.addEventListener('keydown', (e) => {
    if (!lightbox?.classList.contains('lightbox--open')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') showLightboxSlide((current - 1 + totalSlides) % totalSlides);
    if (e.key === 'ArrowRight') showLightboxSlide((current + 1) % totalSlides);
  });
</script>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: 1rem;
    color: var(--color-muted);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .product-section {
    padding: 4rem 0;
  }

  .product-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* ── Carousel ── */
  .carousel {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    background: var(--color-border);
  }

  .carousel-track {
    display: flex;
    transition: transform 0.35s ease;
    will-change: transform;
  }

  .carousel-slide {
    flex: 0 0 100%;
  }

  .carousel-image {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    cursor: zoom-in;
  }

  .carousel-placeholder {
    aspect-ratio: 3 / 4;
    background: var(--color-border);
  }

  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.9);
    border: none;
    border-radius: 50%;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--color-primary);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    transition: background 0.2s, transform 0.2s;
    z-index: 2;
  }

  .carousel-btn:hover {
    background: #fff;
    transform: translateY(-50%) scale(1.08);
  }

  .carousel-btn--prev { left: 0.75rem; }
  .carousel-btn--next { right: 0.75rem; }

  .carousel-dots {
    position: absolute;
    bottom: 0.75rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.4rem;
    z-index: 2;
  }

  .carousel-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.5);
    cursor: pointer;
    padding: 0;
    transition: background 0.2s, transform 0.2s;
  }

  .carousel-dot--active {
    background: #fff;
    transform: scale(1.3);
  }

  /* ── Thumbnail strip ── */
  .carousel-thumbs {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }

  .carousel-thumb {
    flex: 0 0 auto;
    width: 72px;
    height: 72px;
    border-radius: 8px;
    overflow: hidden;
    border: 2px solid transparent;
    padding: 0;
    cursor: pointer;
    transition: border-color 0.2s, opacity 0.2s;
    background: none;
    opacity: 0.6;
  }

  .carousel-thumb:hover {
    opacity: 1;
  }

  .carousel-thumb--active {
    border-color: var(--color-accent);
    opacity: 1;
  }

  .carousel-thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Lightbox ── */
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    align-items: center;
    justify-content: center;
  }

  .lightbox--open {
    display: flex;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.88);
  }

  .lightbox-content {
    position: relative;
    z-index: 1;
    max-width: min(90vw, 1200px);
    max-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox-image {
    max-width: 100%;
    max-height: 90vh;
    width: auto;
    height: auto;
    border-radius: 8px;
    display: block;
    box-shadow: 0 8px 64px rgba(0, 0, 0, 0.5);
  }

  .lightbox-close {
    position: fixed;
    top: 1.25rem;
    right: 1.25rem;
    z-index: 2;
    background: rgba(255, 255, 255, 0.15);
    border: none;
    border-radius: 50%;
    width: 2.75rem;
    height: 2.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #fff;
    transition: background 0.2s;
  }

  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.3);
  }

  .lightbox-nav {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    background: rgba(255, 255, 255, 0.15);
    border: none;
    border-radius: 50%;
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #fff;
    transition: background 0.2s;
  }

  .lightbox-nav:hover {
    background: rgba(255, 255, 255, 0.3);
  }

  .lightbox-nav--prev { left: 1.25rem; }
  .lightbox-nav--next { right: 1.25rem; }

  /* ── Product details ── */
  .product-name {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    color: var(--color-primary);
    margin-bottom: 1.25rem;
    line-height: 1.2;
  }

  .product-desc {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text);
    margin-bottom: 2rem;
  }

  .product-desc :global(h2),
  .product-desc :global(h3) {
    font-family: var(--font-heading), serif;
    font-weight: 600;
    color: var(--color-primary);
    margin-top: 1.75rem;
    margin-bottom: 0.6rem;
    line-height: 1.3;
  }

  .product-desc :global(h2) { font-size: 1.3rem; }
  .product-desc :global(h3) { font-size: 1.1rem; }

  .product-desc :global(ul),
  .product-desc :global(ol) {
    padding-left: 1.4rem;
    margin-bottom: 1rem;
  }

  .product-desc :global(li) {
    margin-bottom: 0.35rem;
  }

  .product-desc :global(p) {
    margin-bottom: 1rem;
  }

  .product-price {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 1.5rem;
  }

  @media (max-width: 768px) {
    .product-layout {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
