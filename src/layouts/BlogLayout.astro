---
import Layout from './Layout.astro';
import HeroImage from '../components/HeroImage.astro';
import { renderMarkdown } from '../lib/markdown';
import 'lite-youtube-embed/src/lite-yt-embed.css';

interface Props {
  post: {
    fields: {
      title: string;
      heroImage?: unknown;
      blogCategory?: unknown[];
      body: string;
      description?: string;
      publishDate?: string;
    };
  };
}

const { post } = Astro.props;
const { title, heroImage, blogCategory, body, description, publishDate } = post.fields;

const html = await renderMarkdown(body ?? '');

const raw = blogCategory as any;
const categories: any[] = raw ? (Array.isArray(raw) ? raw : [raw]) : [];
const categoryName: string = categories[0]?.fields?.category ?? '';

function categoryHref(name: string): string {
  if (name === 'Alles voor beginners') return '/beginners/';
  if (name === 'Tips & Tricks') return '/tips-tricks/';
  return '/';
}

const backHref = categoryHref(categoryName);

const imageAsset = heroImage as any;
const ogImage: string | undefined = imageAsset?.fields?.file?.url ?? undefined;

---

<Layout title={title} {description} {ogImage} ogType="article" datePublished={publishDate}>
  <article class="blog-post">
    {heroImage && (
      <div class="post-hero">
        <HeroImage asset={heroImage} alt={title} />
      </div>
    )}

    <div class="post-header container">
      {categoryName && <a href={backHref} class="post-category">{categoryName}</a>}
      <h1 class="post-title">{title}</h1>
    </div>

    <div class="post-body container" set:html={html} />

    <div class="post-donation">
      <a href="/donate/" class="btn-primary">Leuk blog? Doneer ❤</a>
    </div>
  </article>
</Layout>

<style>
  .blog-post {
    padding-bottom: 4rem;
  }

  .post-hero {
    max-width: 680px;
    margin: 2rem auto 0;
    padding: 0 1.5rem;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    border-radius: 8px;
  }

  .post-hero :global(.hero-image) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 8px;
  }

  .post-header {
    max-width: 680px;
    margin: 2.5rem auto;
  }

  .post-category {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--color-accent);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .post-category:hover {
    opacity: 0.75;
  }

  .post-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    color: var(--color-primary);
    line-height: 1.2;
  }

  /* ── Article body typography ── */
  .post-body {
    max-width: 680px;
    margin: 0 auto 3rem;
  }

  .post-body :global(p) {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--color-text);
    margin-bottom: 1.5rem;
  }

  .post-body :global(h2) {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.6rem;
    color: var(--color-primary);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .post-body :global(h3) {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.3rem;
    color: var(--color-primary);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .post-body :global(a) {
    color: var(--color-accent);
    text-decoration: none;
  }

  .post-body :global(a:hover) {
    text-decoration: underline;
  }

  .post-body :global(img) {
    width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
    margin: 1.5rem 0;
  }

  .post-body :global(blockquote) {
    border-left: 4px solid var(--color-accent);
    padding-left: 1.25rem;
    margin: 2rem 0;
    font-family: var(--font-heading);
    font-style: italic;
    color: var(--color-muted);
  }

  .post-body :global(strong) {
    font-weight: 700;
    color: var(--color-primary);
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .post-body :global(li) {
    font-size: 1.1rem;
    line-height: 1.8;
    margin-bottom: 0.5rem;
  }

  /* ── YouTube embeds ── */
  .post-body :global(.youtube-embed) {
    margin: 2rem 0;
    border-radius: 8px;
    overflow: hidden;
  }
  .post-body :global(.youtube-embed lite-youtube) {
    border-radius: 8px;
  }

  /* ── Donation ── */
  .post-donation {
    text-align: center;
    padding: 2rem 1rem 0;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .post-hero {
      margin-top: 1.5rem;
      padding: 0;
      border-radius: 0;
    }
    .post-hero-image {
      border-radius: 0;
    }
  }
</style>

<script>
  import 'lite-youtube-embed/src/lite-yt-embed.js';
</script>
