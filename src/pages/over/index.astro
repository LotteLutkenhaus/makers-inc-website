---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { getPersonEntry } from '../../lib/contentful';
import { renderMarkdown } from '../../lib/markdown';
import { contentfulImageUrl } from '../../lib/contentful-image';

const person = await getPersonEntry();

const personAsset = person?.fields.image as any;
const personRawUrl: string | null = personAsset?.fields?.file?.url ?? null;
const personImageUrl: string | null = personRawUrl ? contentfulImageUrl(personRawUrl, 'hero') : null;

const html = person?.fields.shortBio ? await renderMarkdown(person.fields.shortBio) : '';
---

<Layout title="Over mij">
  <article class="over-page">
    {personImageUrl && (
      <div class="post-hero">
        <Image
          src={personImageUrl}
          width={680}
          height={453}
          alt={person?.fields.name ?? 'Makers Inc.'}
          class="post-hero-image"
          loading="eager"
        />
      </div>
    )}

    <div class="post-header">
      <h1 class="post-title">{person?.fields.name ?? 'Over mij'}</h1>
    </div>

    {html && (
      <div class="post-body" set:html={html} />
    )}
  </article>
</Layout>

<style>
  .over-page {
    padding-bottom: 4rem;
  }

  .post-hero {
    max-width: 680px;
    margin: 2.5rem auto 0;
    padding: 0 1.5rem;
    overflow: hidden;
    border-radius: 8px;
  }

  .post-hero-image {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 8px;
  }

  .post-header {
    max-width: 680px;
    margin: 2.5rem auto 0;
    padding: 0 1.5rem;
  }

  .post-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    color: var(--color-primary);
    line-height: 1.2;
  }

  .post-body {
    max-width: 680px;
    margin: 2rem auto 0;
    padding: 0 1.5rem;
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .post-body :global(p) {
    margin-bottom: 1.5rem;
  }

  .post-body :global(h2) {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.6rem;
    color: var(--color-primary);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .post-body :global(h3) {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.3rem;
    color: var(--color-primary);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .post-body :global(a) {
    color: var(--color-accent);
    text-decoration: none;
  }

  .post-body :global(a:hover) {
    text-decoration: underline;
  }

  .post-body :global(strong) {
    font-weight: 700;
    color: var(--color-primary);
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .post-body :global(li) {
    margin-bottom: 0.5rem;
  }

</style>
