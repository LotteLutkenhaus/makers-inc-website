---
import LegalPage from '../../components/LegalPage.astro';
import { getLegalInformation } from '../../lib/contentful';

const legal = await getLegalInformation('Privacyverklaring');
---

<LegalPage
  title={legal?.fields.title ?? 'Privacyverklaring'}
  content={legal?.fields.content ?? null}
  fallbackMessage="De privacyverklaring is momenteel niet beschikbaar."
/>
