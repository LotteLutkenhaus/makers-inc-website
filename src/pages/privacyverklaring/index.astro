---
import Layout from '../../layouts/Layout.astro';
import { getLegalInformation } from '../../lib/contentful';
import { renderMarkdown } from '../../lib/markdown';

const legal = await getLegalInformation('Privacyverklaring');
---

<Layout title="Privacyverklaring">
  <div class="page-header">
    <div class="container">
      <h1 class="page-title">{legal?.fields.title ?? 'Privacyverklaring'}</h1>
    </div>
  </div>

  <div class="page-content container">
    {legal ? (
      <div class="legal-body" set:html={renderMarkdown(legal.fields.content ?? '')} />
    ) : (
      <p>De privacyverklaring is momenteel niet beschikbaar.</p>
    )}
  </div>
</Layout>

<style>
  .page-content {
    max-width: 680px;
    margin: 4rem auto;
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .legal-body :global(h2) {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.3rem;
    color: var(--color-primary);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .legal-body :global(p) {
    margin-bottom: 1rem;
  }

  .legal-body :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
  }
</style>
