---
import LegalPage from '../../components/LegalPage.astro';
import { getLegalInformation } from '../../lib/contentful';

const legal = await getLegalInformation('Algemene Voorwaarden');
---

<LegalPage
  title={legal?.fields.title ?? 'Algemene voorwaarden'}
  content={legal?.fields.content ?? null}
  fallbackMessage="De algemene voorwaarden zijn momenteel niet beschikbaar."
/>
