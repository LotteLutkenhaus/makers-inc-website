---
import Layout from '../layouts/Layout.astro';
import { renderMarkdown } from '../lib/markdown';

interface Props {
  title: string;
  description?: string;
  backHref: string;
  backLabel: string;
  icon: 'heart' | 'check';
}

const { title, description, backHref, backLabel, icon } = Astro.props;
---

<Layout title={title}>
  <div class="container success-wrapper">
    <div class="success-icon" aria-hidden="true">
      {icon === 'heart' ? (
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
      ) : (
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
          <polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
      )}
    </div>
    <h1 class="success-title">{title}</h1>
    {description && (
      <div class="success-body" set:html={renderMarkdown(description)} />
    )}
    <a href={backHref} class="btn-primary">{backLabel}</a>
  </div>
</Layout>

<style>
  .success-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-block: 5rem;
    max-width: 640px;
  }

  .success-icon {
    color: var(--color-accent);
    margin-bottom: 1.5rem;
  }

  .success-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }

  .success-body {
    font-family: var(--font-body);
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--color-text);
    margin-bottom: 2.5rem;
  }

  .success-body :global(p) {
    margin-bottom: 1rem;
  }

  .success-body :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
