---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { getDownloads } from '../../lib/contentful';
import { renderMarkdown } from '../../lib/markdown';
import DonateCard from '../../components/DonateCard.astro';

export async function getStaticPaths() {
  const downloads = await getDownloads();
  return downloads.map((dl) => ({
    params: { slug: dl.fields.slug },
    props: { download: dl },
  }));
}

const { download } = Astro.props;
const title = download.fields.newName ?? download.fields.title ?? '';
const description = download.fields.description ?? '';

const file = download.fields.file as any;
const fileUrl = file?.fields?.file?.url ?? '#';
const fullFileUrl = fileUrl.startsWith('//') ? `https:${fileUrl}` : fileUrl;

const imageAsset = (download.fields as any).image as any;
const imageUrl: string | null = imageAsset?.fields?.file?.url
  ? `https:${imageAsset.fields.file.url}`
  : null;
---

<Layout title={title}>
  <section class="download-section">
    <div class="container download-layout">

      <div class="download-main">
        {imageUrl && (
          <div class="download-image-wrap">
            <Image
              src={imageUrl}
              width={560}
              height={560}
              alt={title}
              class="download-image"
            />
          </div>
        )}

        <div class="download-info">
          <a href="/shop/" class="back-link">&larr; Alle patronen</a>
          <h1 class="download-title">{title}</h1>
          {description && <div class="download-desc" set:html={renderMarkdown(description)} />}

          <a href={fullFileUrl} download class="btn-primary download-btn">
            Downloaden
          </a>
        </div>
      </div>

      <DonateCard />

    </div>
  </section>
</Layout>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: 1rem;
    color: var(--color-muted);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .download-section {
    padding: 4rem 0 5rem;
  }

  .download-layout {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 4rem;
    align-items: start;
  }

  .download-main {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .download-image-wrap {
    border-radius: 12px;
    overflow: hidden;
    width: 380px;
    height: 380px;
  }

  .download-image {
    width: 380px;
    height: 380px;
    object-fit: cover;
    display: block;
  }

  .download-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    color: var(--color-primary);
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .download-desc {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-text);
    margin-bottom: 2rem;
    max-width: 560px;
  }

  .download-btn {
    display: inline-block;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .download-layout {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

</style>
