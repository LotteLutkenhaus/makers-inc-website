---
import Layout from '../layouts/Layout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getBlogPosts, getSiteInfo, getProduct } from '../lib/contentful';

const siteInfo = await getSiteInfo();
const posts = await getBlogPosts();
const recentPosts = posts.slice(0, 6);
const product = await getProduct('naaipatroon-maxi-wikkelrok');

const heroAsset = siteInfo?.fields.heroImage as any;
const heroImageUrl: string | null = heroAsset?.fields?.file?.url
  ? `https:${heroAsset.fields.file.url}`
  : null;

const productPrice = product?.fields.price;
---

<Layout title="Home">
  <!-- Cinematic hero -->
  <section
    class="hero"
    style={heroImageUrl ? `background-image: url('${heroImageUrl}')` : ''}
  >
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <h1 class="hero-title">Hi! Ik ben Lotte.</h1>
      <p class="hero-subtitle">Makers Inc. is mijn blog, waarin ik handige tips en tricks voor het naaien van kleding met je deel.</p>
    </div>
  </section>

  <!-- Micro-intro strip -->
  <section class="intro">
    <div class="intro-inner">
      <p>Naaien lijkt ingewikkeld — maar dat hoeft het niet te zijn. Op Makers Inc. vind je eerlijke tutorials, praktische tips en gratis patronen, speciaal geschreven voor beginners. Geen ingewikkeld jargon, gewoon lekker aan de slag.</p>
    </div>
  </section>

  <!-- Nieuw hier? -->
  <section class="nieuw-hier">
    <div class="container">
      <h2 class="section-title">Nieuw hier?</h2>
      <div class="nieuw-cards">
        <a
          href="/blog/naaien-voor-beginners-stap-voor-stap-tutorial-voor-een-etui/"
          class="nieuw-card"
        >
          <span class="nieuw-label">Gratis tutorial</span>
          <h3 class="nieuw-card-title">Leer een etui naaien &mdash; stap voor stap</h3>
          <span class="nieuw-pill nieuw-pill--gratis">&#x2713; Gratis</span>
        </a>
        <a href="/shop/" class="nieuw-card">
          <span class="nieuw-label">Naaipatroon</span>
          <h3 class="nieuw-card-title">Maxi-wikkelrok &mdash; je eerste kledingstuk</h3>
          {productPrice !== undefined && (
            <span class="nieuw-pill nieuw-pill--price">&euro;{productPrice.toFixed(2)}</span>
          )}
        </a>
      </div>
    </div>
  </section>

  <!-- Recente blogposts -->
  <section class="recent-posts">
    <div class="container">
      <h2 class="section-title">Recente blogposts</h2>
      <div class="posts-grid">
        {recentPosts.map((post) => (
          <BlogCard post={post} />
        ))}
      </div>
      <div class="posts-cta">
        <a href="/beginners/" class="btn-outline">Alle blogposts bekijken &rarr;</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    min-height: 70vh;
    background-color: var(--color-primary);
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.72) 0%,
      rgba(0, 0, 0, 0.3) 55%,
      transparent 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 600px;
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    color: #fff;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }

  .hero-subtitle {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: clamp(1rem, 2.5vw, 1.35rem);
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.6;
  }

  /* ── Micro-intro ── */
  .intro {
    background: var(--color-surface);
    padding: 3.5rem 2rem;
  }

  .intro-inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  /* ── Nieuw hier? ── */
  .nieuw-hier {
    background: var(--color-bg);
    padding: 4rem 0;
  }

  .section-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.8rem;
    color: var(--color-primary);
    margin-bottom: 2rem;
  }

  .nieuw-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .nieuw-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 2rem;
    background: var(--color-surface);
    border: 1.5px solid var(--color-border);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .nieuw-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }

  .nieuw-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }

  .nieuw-card:hover::before {
    transform: scaleX(1);
  }

  .nieuw-label {
    color: var(--color-accent);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .nieuw-card-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.2rem;
    color: var(--color-primary);
    line-height: 1.3;
  }

  .nieuw-pill {
    display: inline-block;
    align-self: flex-start;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .nieuw-pill--gratis {
    background: rgba(46, 87, 68, 0.12);
    color: var(--color-primary);
  }

  .nieuw-pill--price {
    background: var(--color-bg);
    color: var(--color-primary);
    border: 1px solid var(--color-border);
    font-family: var(--font-heading);
    font-size: 1rem;
  }

  /* ── Recente blogposts ── */
  .recent-posts {
    padding: 4rem 0;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .posts-cta {
    text-align: center;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .nieuw-cards {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: 55vh;
    }
  }

  @media (max-width: 900px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
